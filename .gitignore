# =========================================
# MONO-REPO: Frontend + Backend
# =========================================

# Node modules
**/node_modules/
npm-debug.log
yarn-error.log
pnpm-debug.log

# =========================================
# FRONTEND (Angular)
# =========================================

# Compiled output
/frontend/dist
/frontend/tmp
/frontend/out-tsc
/frontend/bazel-out

# Angular cache
/frontend/.angular/cache
/frontend/.sass-cache/

# Coverage
/frontend/coverage

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Miscellaneous
/frontend/connect.lock
/frontend/libpeerconnection.log
/frontend/testem.log
/frontend/typings
/frontend/__screenshots__/

# =========================================
# BACKEND (Node.js + Express)
# =========================================

# Build output
/backend/dist
/backend/build
/backend/coverage

# Environment variables
/backend/.env
/backend/.env.local
/backend/.env.*.local

# Logs
/backend/logs
/backend/*.log

# TypeScript build info
*.tsbuildinfo

# Source maps (optional - uncomment if you don't want them in repo)
# *.map

# =========================================
# DATABASE (PostgreSQL + Prisma)
# =========================================

# Prisma
/backend/prisma/migrations/*_migration.sql.bak
/backend/prisma/*.db
/backend/prisma/*.db-journal

# Database files (if using SQLite for testing)
*.db
*.db-journal

# Prisma generated files (auto-generated by Prisma Client)
**/node_modules/.prisma/
**/node_modules/@prisma/client/

# =========================================
# DOCKER
# =========================================

# Docker volumes
postgres-data/
pgdata/

# =========================================
# SYSTEM FILES
# =========================================

.DS_Store
Thumbs.db
*.swp
*.swo
*~

# =========================================
# TESTING
# =========================================

/frontend/.nyc_output
/backend/.nyc_output

# =========================================
# MISC
# =========================================

# Lock files (optional - some teams commit these)
# Uncomment if you want to ignore lock files
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Temporary files
*.tmp
*.temp
.temp/
.tmp/

# OS generated files
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Editor backup files
*~
*.bak
*.swp
*.swo