# ============================================
# DATABASE
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Transaction pooler URL (port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meppos_db"

# Direct connection URL (port 5432) — used by Prisma migrations only
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/meppos_db"

# ============================================
# SERVER
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CORS
# ============================================
# Frontend URL (Angular in development)
FRONTEND_URL=http://localhost:4200

# ============================================
# AUTHENTICATION
# ============================================
# JWT secrets — REQUIRED in production, optional in dev (has fallback)
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret

# Default admin password used by prisma/seed.ts (fallback: admin123)
ADMIN_DEFAULT_PASSWORD=admin123

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Copy this file as .env
# 2. Adjust values according to your setup
# 3. DO NOT commit the .env file (already in .gitignore)
# 4. In production, JWT secrets MUST be set (app will refuse to start without them)